# smithr.yml.example — Smithr configuration for your project
#
# Copy this to smithr.yml in your project root and customise.
# All paths are relative to the directory containing smithr.yml
# unless they begin with / (absolute).
#
# Used by: smithr server start, smithr test run, smithr build
# Parser: Python3 + PyYAML → JSON → jq (see bin/lib/config.sh)

# ─── Project Identity ──────────────────────────────────────
project:
  name: myapp                           # Project name
  app_id: com.myorg.myapp               # Mobile app package ID

# ─── Server Environment ────────────────────────────────────
server:
  # Database credentials (overrides Smithr defaults)
  db:
    user: myapp
    password: myapp_dev_password
    name: myapp

  # Environment variables for setup commands
  # These are exported before running setup commands
  env:
    DATABASE_URL: "postgresql://myapp:myapp_dev_password@localhost:5432/myapp"
    REDIS_URL: "redis://localhost:6379"

  # Commands to run after database is healthy (in order)
  # Run from the project root directory
  setup:
    - "pnpm install --frozen-lockfile"
    - "pnpm db:migrate"
    - "pnpm db:seed"

  # Project API server (started via Docker Compose)
  api:
    compose: "docker/api.yml"           # Path to project's compose file
    container: "myapp-api"              # Container name for health checks
    health_url: "http://localhost:3000/api/health"  # HTTP health endpoint
    health_timeout: 60                  # Seconds to wait for healthy
    env:                                # Env vars for the API container
      NODE_ENV: "production"
      DATABASE_URL: "postgresql://myapp:myapp_dev_password@smithr-postgres:5432/myapp"
      REDIS_URL: "redis://smithr-redis:6379"

# ─── Mobile Apps ────────────────────────────────────────────
mobile:
  android:
    apk: "path/to/app-release.apk"     # Pre-built APK (relative to smithr.yml)
    build: "./bin/build-android.sh"     # Build command (if APK not pre-built)
  ios:
    app: "path/to/MyApp.tar.gz"        # Pre-built iOS app bundle

# ─── Test Configuration ─────────────────────────────────────
tests:
  dir: "tests/mobile"                   # Directory containing test files
  default:                              # Tests to run by default
    - "smoke-test.yaml"
    - "login-test.yaml"

# ─── Network ────────────────────────────────────────────────
network:
  # ADB reverse mappings: route emulator localhost → host port
  # Format: "device_port host_port"
  adb_reverse:
    - "3000 3000"
