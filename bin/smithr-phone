#!/usr/bin/env bash
# smithr phone — Manage the phone pool
#
# Usage:
#   smithr phone get    --type <device>    Acquire a phone from the warm pool
#   smithr phone unlease <handle>           Return a phone to the pool
#   smithr phone list                      List all phones and their status
#   smithr phone status                    Show pool summary
#   smithr phone warm   [--count N]        Pre-warm N phones (default: from config)
#   smithr phone reap                      Clean up expired leases
#   smithr phone shutdown                  Gracefully shut down all phones (reverse order)

set -euo pipefail

SMITHR_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "${SMITHR_ROOT}/bin/lib/common.sh"
source "${SMITHR_ROOT}/bin/lib/phone-pool.sh"

# Smithr API endpoint
SMITHR_API="${SMITHR_API_URL:-http://localhost:7070}"

usage() {
    cat <<EOF
smithr phone — Manage the phone pool

Usage:
  smithr phone get [--platform android|ios] [--ttl 1800] [--lessee name]
      Acquire a warm phone via the Smithr API. Returns lease ID on stdout.

  smithr phone unlease <lease-id>
      Unlease a phone back to the pool.

  smithr phone info <lease-id>
      Show connection details for a lease.

  smithr phone list [--platform android|ios] [--status warm|leased|shared]
      List all resources and their status.

  smithr phone status
      Show pool summary.

  smithr phone warm [--platform android] [--type pixel_7] [--count 4]
      Pre-warm phones into the pool. Starts containers and waits for health.

  smithr phone shutdown [--all]
      Gracefully shut down phones. Reverse order of startup.
      --all shuts down every phone. Without --all, only idle phones.

Options:
  --platform     Phone platform: android, ios, or macos (default: android)
  --ttl          Lease duration in seconds (default: 1800)
  --lessee       Lessee identifier (default: \$USER)
  --help         Show this help

Environment:
  SMITHR_API_URL   API endpoint (default: http://localhost:7070)
EOF
}

# Parse global options
PLATFORM="android"
DEVICE_TYPE=""
COUNT=1
TTL=1800
LESSEE="${USER:-anonymous}"
STATUS_FILTER=""

# API helper: call the Smithr API
api_call() {
    local method="$1" path="$2"
    shift 2
    local url="${SMITHR_API}${path}"
    local result
    result=$(curl -sf -X "$method" -H "Content-Type: application/json" "$@" "$url" 2>/dev/null) || {
        log_error "API call failed: $method $path" >&2
        return 1
    }
    echo "$result"
}

cmd_get() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type) DEVICE_TYPE="$2"; shift 2 ;;
            --platform) PLATFORM="$2"; shift 2 ;;
            --ttl) TTL="$2"; shift 2 ;;
            --lessee) LESSEE="$2"; shift 2 ;;
            *) die "Unknown option for get: $1" ;;
        esac
    done

    # Map platform to resource type
    local res_type="phone"
    if [[ "$PLATFORM" == "macos" ]]; then
        res_type="vm"
    fi

    local body
    body=$(jq -n \
        --arg type "$res_type" \
        --arg platform "$PLATFORM" \
        --argjson ttl "$TTL" \
        --arg lessee "$LESSEE" \
        '{type: $type, platform: $platform, ttl_seconds: $ttl, lessee: $lessee}')

    local response
    response=$(api_call POST /api/leases -d "$body") || die "Failed to acquire lease"

    local lease_id tunnel_port resource_id
    lease_id=$(echo "$response" | jq -r '.id')
    tunnel_port=$(echo "$response" | jq -r '.connection.tunnel_port // empty')
    resource_id=$(echo "$response" | jq -r '.resource_id')

    log_ok "Acquired lease: ${lease_id}" >&2
    log_info "  Resource: ${resource_id}" >&2
    [[ -n "$tunnel_port" ]] && log_info "  Tunnel: localhost:${tunnel_port}" >&2

    # Output lease ID on stdout (this is the handle)
    echo "$lease_id"
}

cmd_unlease() {
    local lease_id="${1:?Usage: smithr phone unlease <lease-id>}"
    api_call DELETE "/api/leases/${lease_id}" >/dev/null || die "Failed to unlease ${lease_id}"
    log_ok "Unleased: ${lease_id}"
}

cmd_info() {
    local lease_id="${1:?Usage: smithr phone info <lease-id>}"
    local response
    response=$(api_call GET "/api/leases/${lease_id}") || die "Lease not found: ${lease_id}"
    echo "$response" | jq .
}

cmd_list() {
    local query=""
    [[ "$PLATFORM" != "android" ]] && query="?platform=${PLATFORM}"
    [[ -n "$STATUS_FILTER" ]] && {
        if [[ -n "$query" ]]; then
            query="${query}&status=${STATUS_FILTER}"
        else
            query="?status=${STATUS_FILTER}"
        fi
    }

    local response
    response=$(api_call GET "/api/resources${query}") || die "Failed to list resources"

    echo "$response" | jq -r '.[] | "\(.id)\t\(.platform)\t\(.status)\t\(.container)"' | \
        column -t -s $'\t' -N "ID,PLATFORM,STATUS,CONTAINER"
}

cmd_status() {
    local response
    response=$(api_call GET /api/health) || die "Failed to get status"

    local status hosts resources leases
    status=$(echo "$response" | jq -r '.status')
    hosts=$(echo "$response" | jq -r '.hosts')
    resources=$(echo "$response" | jq -r '.resources')
    leases=$(echo "$response" | jq -r '.leases')

    echo -e "${BOLD}Smithr Status${NC}"
    echo -e "  Status:    $(if [[ "$status" == "ok" ]]; then echo -e "${GREEN}${status}${NC}"; else echo -e "${RED}${status}${NC}"; fi)"
    echo -e "  Hosts:     ${hosts}"
    echo -e "  Resources: ${resources}"
    echo -e "  Leases:    ${leases}"

    if [[ $leases -gt 0 ]]; then
        echo ""
        echo -e "${BOLD}Active Leases:${NC}"
        local lease_list
        lease_list=$(api_call GET /api/leases) || return 0
        echo "$lease_list" | jq -r '.[] | "  \(.id | .[0:8])  \(.resource_id)  \(.lessee)  \(.expires_at)"'
    fi
}

cmd_warm() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --platform) PLATFORM="$2"; shift 2 ;;
            --type) DEVICE_TYPE="$2"; shift 2 ;;
            --count) COUNT="$2"; shift 2 ;;
            *) die "Unknown option for warm: $1" ;;
        esac
    done

    local default_type
    if [[ "$PLATFORM" == "android" ]]; then
        default_type="${DEVICE_TYPE:-Nexus 5}"
    else
        default_type="${DEVICE_TYPE:-iPhone 16}"
    fi

    local hostname
    hostname=$(hostname)

    log_info "Warming ${COUNT} ${PLATFORM} phone(s) (${default_type}) on ${hostname}..."

    for i in $(seq 0 $((COUNT - 1))); do
        local port=$((5555 + i))
        local vnc_port=$((5900 + i))
        local novnc_port=$((6080 + i))
        local ip_offset=$((30 + i))
        local ip="10.21.0.${ip_offset}"
        local project_name="smithr-phone-${PLATFORM}-${i}"

        log_info "Starting phone ${i} (${default_type}) at ${ip}:${port}..."

        if [[ "$PLATFORM" == "android" ]]; then
            # Ensure network exists
            docker network create "${SMITHR_NETWORK_NAME:-smithr-network}" \
                --subnet="${SMITHR_NETWORK_SUBNET:-10.21.0.0/16}" 2>/dev/null || true

            SMITHR_ANDROID_ID="$i" \
            SMITHR_ANDROID_DEVICE="$default_type" \
            SMITHR_ANDROID_ADB_PORT="$port" \
            SMITHR_ANDROID_VNC_PORT="$vnc_port" \
            SMITHR_ANDROID_NOVNC_PORT="$novnc_port" \
            SMITHR_ANDROID_IP="$ip" \
            docker compose \
                -f "${SMITHR_ROOT}/layers/network.yml" \
                -f "${SMITHR_ROOT}/layers/android.yml" \
                -p "$project_name" \
                up -d

            # Wait for the emulator to boot
            wait_for_healthy "smithr-android-${i}" 300

            # Clojure service auto-discovers via Docker events
            log_ok "Android phone ${i} started (Smithr will auto-discover)"
        elif [[ "$PLATFORM" == "ios" ]]; then
            # iOS uses macOS VM + iOS Simulator
            # Port allocation: SSH starts at 50922, VNC at 5999
            local ssh_port=$((50922 + i))
            local vnc_port=$((5999 + i))
            local ip_offset=$((40 + i))
            local ip="10.21.0.${ip_offset}"
            local macos_image="${SMITHR_MACOS_IMAGE:-/srv/shared/images/artha-sonoma.img}"

            [[ -f "$macos_image" ]] || die "macOS image not found: $macos_image"

            # Ensure network exists
            docker network create "${SMITHR_NETWORK_NAME:-smithr-network}" \
                --subnet="${SMITHR_NETWORK_SUBNET:-10.21.0.0/16}" 2>/dev/null || true

            log_info "Starting macOS VM ${i} (${default_type}) at ${ip} (SSH:${ssh_port}, VNC:${vnc_port})..."

            SMITHR_IOS_VM_ID="$i" \
            SMITHR_IOS_DEVICE="$default_type" \
            SMITHR_MACOS_IMAGE="$macos_image" \
            SMITHR_MACOS_SSH_PORT="$ssh_port" \
            SMITHR_MACOS_VNC_PORT="$vnc_port" \
            SMITHR_MACOS_IP="$ip" \
            docker compose \
                -f "${SMITHR_ROOT}/layers/network.yml" \
                -f "${SMITHR_ROOT}/layers/ios.yml" \
                -f "${SMITHR_ROOT}/layers/ios-sim.yml" \
                -p "$project_name" \
                up -d

            # macOS VM takes much longer to boot than Android (~2-5 minutes)
            local container_name="${SMITHR_PREFIX:-smithr}-ios-${i}"
            wait_for_healthy "$container_name" 600

            # Wait for simulator sidecar too
            local sim_container="${container_name}-sim"
            log_info "Waiting for iOS Simulator to boot..."
            wait_for_healthy "$sim_container" 300

            # Clojure service auto-discovers via Docker events
            log_ok "iOS phone ${i} started (Smithr will auto-discover)"
        else
            die "Unknown platform: $PLATFORM (expected: android or ios)"
        fi
    done

    log_ok "All ${COUNT} phone(s) warmed and registered"
}

cmd_shutdown() {
    local all=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all) all=true; shift ;;
            *) die "Unknown option for shutdown: $1" ;;
        esac
    done

    # Get resources from the API
    local query=""
    if ! $all; then
        query="?status=warm"
    fi

    local resources
    resources=$(api_call GET "/api/resources${query}") || die "Failed to list resources"

    local ids
    ids=$(echo "$resources" | jq -r '.[].container')

    if [[ -z "$ids" || "$ids" == "null" ]]; then
        log_info "No phones to shut down"
        return 0
    fi

    while IFS= read -r container; do
        [[ -n "$container" ]] || continue
        log_info "Shutting down: ${container}"

        # Stop the container directly
        docker stop --time 30 "$container" 2>/dev/null || true

        # Clojure service will detect the 'die' event and remove from state
        log_ok "Shut down: ${container}"
    done <<< "$ids"

    log_ok "Phone shutdown complete"
}

# Dispatch
case "${1:-}" in
    get)      shift; cmd_get "$@" ;;
    unlease)  shift; cmd_unlease "$@" ;;
    info)     shift; cmd_info "$@" ;;
    list)     shift 2>/dev/null || true; cmd_list ;;
    status)   cmd_status ;;
    warm)     shift; cmd_warm "$@" ;;
    shutdown) shift; cmd_shutdown "$@" ;;
    help|--help|-h) usage ;;
    *) usage; exit 1 ;;
esac
