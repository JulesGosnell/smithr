{:server {:port 7070
          :host "0.0.0.0"}

 ;; Local host first (unix socket), then remote hosts.
 ;; Remote hosts use TLS — Docker daemon listens on port 2376 with mutual TLS.
 ;; Cert dir must contain: ca.pem, cert.pem, key.pem
 :hosts [{:label "megalodon"}
         {:label "prognathodon"
          :host-address "prognathodon"
          :tls {:cert-path "/etc/smithr/tls"}}]

 :gc {:interval-seconds 30
      :own-host "megalodon"}

 :compose {:project "smithr"
           :network "smithr-network"}

 :tunnel {:key-path "/ssh-key/macos-ssh-key"
          :base-port 17000}

 :provisioning
 {:templates
  {:android-phone   {:compose-files ["layers/android.yml"]
                     :env-template {"SMITHR_ANDROID_RUNE" :auto
                                    "SMITHR_ANDROID_IP" :auto
                                    "SMITHR_ANDROID_ADB_PORT" :auto
                                    "SMITHR_ANDROID_VNC_PORT" :auto
                                    "SMITHR_ANDROID_NOVNC_PORT" :auto}
                     :description "Android emulator with ADB access"
                     :boot-time-seconds 30
                     :catalogue {:type "phone"
                                 :platform "android"
                                 :substrate "emulated"
                                 :os "Android 9.0"}
                     :variants [{:model "Nexus 5"  :resolution "1080x1920" :screen "4.95\"" :device-env {"EMULATOR_DEVICE" "Nexus 5"}}
                                {:model "Nexus 6"  :resolution "1440x2560" :screen "5.96\"" :device-env {"EMULATOR_DEVICE" "Nexus 6"}}
                                {:model "Pixel 2"  :resolution "1080x1920" :screen "5.0\""  :device-env {"EMULATOR_DEVICE" "pixel_2"}}
                                {:model "Pixel 3a" :resolution "1080x2220" :screen "5.6\""  :device-env {"EMULATOR_DEVICE" "pixel_3a"}}
                                {:model "Pixel 5"  :resolution "1080x2340" :screen "6.0\""  :device-env {"EMULATOR_DEVICE" "pixel_5"}}
                                {:model "Pixel 6"  :resolution "1080x2400" :screen "6.4\""  :device-env {"EMULATOR_DEVICE" "pixel_6"}}]}
   :android-build   {:compose-files ["layers/android-build.yml"]
                     :env-template {"SMITHR_ANDROID_BUILD_RUNE" :auto
                                    "SMITHR_ANDROID_BUILD_IP" :auto}
                     :description "Android build container (Fedora + SDK)"
                     :boot-time-seconds 10
                     :catalogue {:type "vm"
                                 :platform "android-build"
                                 :substrate "virtual"
                                 :os "Fedora 43"}
                     :variants [{:model "Fedora 43"}]}
   :sandbox         {:compose-files ["layers/sandbox.yml"]
                     :env-template {"SMITHR_SANDBOX_RUNE" :auto
                                    "SMITHR_SANDBOX_IP" :auto}
                     :description "Headless dev sandbox (Fedora + Claude Code)"
                     :boot-time-seconds 10
                     :catalogue {:type "vm"
                                 :platform "sandbox"
                                 :substrate "virtual"
                                 :os "Fedora 43"}
                     :variants [{:model "Fedora 43"}]}
   :macos-vm        {:compose-files ["layers/xcode.yml"]
                     :env-template {"SMITHR_XCODE_RUNE" :auto
                                    "SMITHR_MACOS_IP" :auto
                                    "SMITHR_MACOS_IMAGE" "/srv/shared/images/smithr-sonoma.img"}
                     :description "macOS + Xcode build VM (shared, up to 10 concurrent)"
                     :boot-time-seconds 180
                     :catalogue {:type "vm"
                                 :platform "macos"
                                 :substrate "virtual"
                                 :os "macOS Sonoma"}
                     :variants [{:model "macOS Sonoma"}]}
   :ios-phone       {:compose-files ["layers/xcode.yml" "layers/ios.yml"]
                     :env-template {"SMITHR_XCODE_RUNE" :auto
                                    "SMITHR_MACOS_IP" :auto
                                    "SMITHR_MACOS_IMAGE" "/srv/shared/images/smithr-sonoma.img"}
                     :description "iOS Simulator inside macOS VM"
                     :boot-time-seconds 120
                     :catalogue {:type "phone"
                                 :platform "ios"
                                 :substrate "simulated"
                                 :os "iOS 18.3"}
                     :variants [{:model "iPhone SE (3rd generation)" :resolution "750x1334"  :screen "4.7\"" :device-env {"SMITHR_IOS_DEVICE" "iPhone SE (3rd generation)"}}
                                {:model "iPhone 12 mini"             :resolution "1080x2340" :screen "5.4\"" :device-env {"SMITHR_IOS_DEVICE" "iPhone 12 mini"}}
                                {:model "iPhone 13"                  :resolution "1170x2532" :screen "6.1\"" :device-env {"SMITHR_IOS_DEVICE" "iPhone 13"}}
                                {:model "iPhone 14 Plus"             :resolution "1284x2778" :screen "6.7\"" :device-env {"SMITHR_IOS_DEVICE" "iPhone 14 Plus"}}
                                {:model "iPhone 15 Pro"              :resolution "1179x2556" :screen "6.1\"" :device-env {"SMITHR_IOS_DEVICE" "iPhone 15 Pro"}}
                                {:model "iPhone 16 Pro Max"          :resolution "1320x2868" :screen "6.9\"" :device-env {"SMITHR_IOS_DEVICE" "iPhone 16 Pro Max"}}
                                {:model "iPhone 16e"                 :resolution "1170x2532" :screen "6.1\"" :device-env {"SMITHR_IOS_DEVICE" "iPhone 16e"}}]}}
  :type-mapping {"phone:android"      :android-phone
                 "phone:ios"          :ios-phone
                 "vm:android-build"   :android-build
                 "vm:sandbox"         :sandbox
                 "vm:macos"           :macos-vm}
  :rune-pool ["fe" "ur" "thurs" "oss" "reid" "kaun" "hagall" "naud"
              "iss" "ar" "sol" "tyr" "bjarkan" "madhr" "logr" "yr"]
  :ip-ranges {:android       {:base "10.21.0" :start 30}
              :android-build {:base "10.21.0" :start 50}
              :sandbox       {:base "10.21.0" :start 60}
              :macos         {:base "10.21.0" :start 40}}
  :port-ranges {:android-adb   {:start 5555}
                :android-vnc   {:start 5900}
                :android-novnc {:start 6080}}
  :idle-timeout-seconds 1800
  :health-timeout-seconds 300
  :local-only true}}
